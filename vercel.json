{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@2.0.0",
      "memory": 1024,
      "includeFiles": "data/**"
    }
  },
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/testimonials", "destination": "/api/testimonials.js" },
    { "source": "/api/programs", "destination": "/api/programs.js" },
    { "source": "/api/events", "destination": "/api/events.js" },
    { "source": "/api/contact", "destination": "/api/contact.js" },
    { "source": "/api/newsletter/subscribe", "destination": "/api/newsletter-subscribe.js" },
    { "source": "/api/user", "destination": "/api/user.js" },
    { "source": "/api/login", "destination": "/api/login.js" },
    { "source": "/api/register", "destination": "/api/register.js" },
    { "source": "/api/logout", "destination": "/api/logout.js" },
    { "source": "/api/profile", "destination": "/api/profile.js" },
    { "source": "/api/profile/(.*)", "destination": "/api/profile.js" },
    { "source": "/api/bookings", "destination": "/api/bookings.js" },
    { "source": "/api/bookings/(.*)", "destination": "/api/bookings.js" },
    { "source": "/(login|profile|bookings|auth)(.*)", "destination": "/" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}